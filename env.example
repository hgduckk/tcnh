# Supabase Configuration
# Get these values from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Admin-only key (server-side). Required for /admin form template saving + /apply submissions storage.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Password used to protect /admin form/template endpoints.
# (Current default fallback is "maiyeuquangan")
ADMIN_PASSWORD=maiyeuquangan

# Google Sheets API Configuration (for application forms and contact forms)
# Bạn cần tạo Google Cloud Project và Service Account để lấy các thông tin này

# ID của Google Sheet (lấy từ URL của sheet)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Range cho Application Form (mặc định: Sheet1!A:I)
GOOGLE_SHEET_RANGE=Sheet1!A:I

# Range cho Contact Form (mặc định: Contact!A:D)
GOOGLE_SHEET_RANGE_CONTACT=Contact!A:D

# Đường dẫn đến file service account key (JSON)
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account-key.json

# Hoặc sử dụng credentials trực tiếp (không khuyến khích cho production)
# GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Hoặc cung cấp toàn bộ JSON credentials ở dạng base64 (khuyến nghị cho production)
# Tạo chuỗi base64 từ file JSON bằng lệnh:
#   base64 -i service-account-key.json | tr -d '\n'
# Lưu ý: Không để chuỗi base64 trong dấu nháy khi set trên dashboard hosting
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Google Drive uses the same service account credentials above.
# Enable Google Drive API in your GCP project.


NEXT_PUBLIC_SANITY_DATASET=xxx
NEXT_PUBLIC_SANITY_PROJECT_ID=xxx